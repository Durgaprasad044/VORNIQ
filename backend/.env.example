# VORNIQ Financial Intelligence Platform
# Environment Configuration
# Copy to .env and fill in your values

# === Application ===
VORNIQ_DEBUG=false
VORNIQ_HOST=0.0.0.0
VORNIQ_PORT=8000
VORNIQ_CORS_ORIGINS=["http://localhost:3000"]

# === Parser Agent ===
PARSER_MAX_UPLOAD_SIZE_MB=50
PARSER_OCR_ENABLED=true
PARSER_OCR_LANGUAGE=eng
PARSER_OCR_DPI=300
PARSER_PROCESSING_TIMEOUT_SECONDS=120

# === Confidence Scoring ===
CONFIDENCE_MINIMUM_THRESHOLD=0.6
CONFIDENCE_HIGH_CONFIDENCE=0.9
CONFIDENCE_OCR_PENALTY=0.15

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Hindsight Memory (future — Memory Agent) ===
# HINDSIGHT_BASE_URL=http://localhost:8888
# HINDSIGHT_BANK_ID=vorniq-memory

# === LLM Provider (future — Runtime Agent) ===
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=your_groq_key_here
